# EmailJS Configuration for Tennis Lesson Booking
# Sign up at https://www.emailjs.com/ to get your credentials

# Your EmailJS Public Key (found in Account > General)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (create a service connected to your email)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_tennis

# Template ID for owner notification email
NEXT_PUBLIC_EMAILJS_TEMPLATE_OWNER=template_booking_owner

# Template ID for customer confirmation email
NEXT_PUBLIC_EMAILJS_TEMPLATE_CUSTOMER=template_booking_customer
